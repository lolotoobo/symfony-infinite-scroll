<div {{ attributes }}>
    <div
        data-controller="infinite-scroll"
        data-infinite-scroll-has-more-value="{{ hasMore ? 'true' : 'false' }}"
    >
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

            {# Posts de la page courante — chaque item a son propre id + data-live-ignore.
               Idiomorph ne les touchera plus jamais après leur premier rendu. #}
            {% for post in currentPosts %}
                <div class="col" id="item--{{ page }}-{{ loop.index }}" data-live-ignore>
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-primary bg-opacity-10 border-0 d-flex align-items-center gap-2">
                            <span class="badge bg-primary rounded-pill">#{{ post.id }}</span>
                            <div class="d-flex gap-1 flex-wrap">
                                {% for tag in post.tags %}
                                    <span class="badge bg-secondary bg-opacity-75 fw-normal">{{ tag }}</span>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title fw-semibold lh-sm mb-2">{{ post.title|capitalize }}</h5>
                            <p class="card-text text-muted small">{{ post.body|slice(0, 120) }}…</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 d-flex justify-content-between text-muted small">
                            <span><i class="bi bi-eye me-1"></i>{{ post.views ?? 0 }}</span>
                            <span>
                                <i class="bi bi-hand-thumbs-up me-1"></i>{{ post.reactions.likes ?? 0 }}
                                <i class="bi bi-hand-thumbs-down ms-2 me-1"></i>{{ post.reactions.dislikes ?? 0 }}
                            </span>
                        </div>
                    </div>
                </div>
            {% endfor %}

            {# Skeletons de la page suivante.
               — Leurs ids (item--N+1-i) matcheront les vrais items au prochain loadMore.
               — Le premier skeleton est le sentinel de l'IntersectionObserver.
               — Pas de data-live-ignore : Idiomorph les remplacera par le vrai contenu. #}
            {% if hasMore %}
                {% for i in 1..perPage %}
                    <div
                        class="col"
                        id="item--{{ page + 1 }}-{{ i }}"
                        {% if loop.first %}data-infinite-scroll-target="sentinel"{% endif %}
                    >
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-header bg-light border-0 placeholder-glow d-flex align-items-center gap-2">
                                <span class="placeholder rounded-pill col-2"></span>
                                <span class="placeholder rounded col-2"></span>
                                <span class="placeholder rounded col-2"></span>
                            </div>
                            <div class="card-body placeholder-glow">
                                <h5 class="mb-3"><span class="placeholder col-9"></span></h5>
                                <p class="mb-0">
                                    <span class="placeholder col-12 d-block mb-1"></span>
                                    <span class="placeholder col-10 d-block mb-1"></span>
                                    <span class="placeholder col-7 d-block"></span>
                                </p>
                            </div>
                            <div class="card-footer bg-transparent border-0 placeholder-glow d-flex justify-content-between">
                                <span class="placeholder col-2"></span>
                                <span class="placeholder col-3"></span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}

        </div>

        {% if not hasMore %}
            <p class="text-center py-5 text-muted mb-0">
                <i class="bi bi-check-circle fs-3 d-block mb-2"></i>
                Tous les articles ont été chargés.
            </p>
        {% endif %}
    </div>
</div>
